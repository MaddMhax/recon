# Copy to .env and adjust before first run:  cp .env.example .env

# ---- Database (PostgreSQL) ----
# docker-compose assembles these into the app's DATABASE_URL. Avoid the
# characters @ : / # ? in the password (or URL-encode them) — they would break
# the connection string. Alphanumerics plus - and _ are safe.
POSTGRES_USER=recon
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_DB=recon

# ---- App / API ----
# Host port the web app is published on
APP_PORT=3000

# Secret used to sign auth tokens — MUST be long and random in production.
# Generate one:  openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=12h

# Send the session cookie only over HTTPS (Secure flag).
#   false -> works over plain HTTP (localhost / no TLS) — default
#   true  -> required once served behind an HTTPS reverse proxy
COOKIE_SECURE=false

# Bootstrap admin account, created on first startup if it does not exist.
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=change-this-admin-password
